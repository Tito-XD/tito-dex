<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash: brand deep blue behind the adaptive
         launcher icon instead of the stock light background. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/tito_deep_blue</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/tito_slate_blue</item>
    </style>
</resources>
